# PollAgg Production Environment
# Copy to .env and fill in real values. NEVER commit .env.

# --- PostgreSQL ---
POSTGRES_USER=polluser
POSTGRES_PASSWORD=change-me-strong-random-string
POSTGRES_DB=polldb

# --- Frontend build-time public URLs ---
# Public API origin used by browser. Must match nginx server_name (api host).
NEXT_PUBLIC_API_URL=https://api-poll.dailyprizm.com/api
# Public dashboard origin (where /view, /dashboard, /mini are served).
NEXT_PUBLIC_DASHBOARD_URL=https://poll.dailyprizm.com
